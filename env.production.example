# docker-compose.prod.yml 용 (복사: cp env.production.example .env.production)

POSTGRES_USER=elivis
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=elivis

# API 컨테이너가 바인딩할 호스트 포트
SERVER_PORT=4000

# 브라우저/웹 앱 출처 (프론트 URL)
CORS_ORIGIN=http://localhost:3000

# 서버·Prisma에 쓰는 URL (호스트에서 마이그레이션 실행 시)
# DATABASE_URL=postgresql://elivis:change-me-in-production@localhost:5432/elivis
