# 프로덕션 배포용 환경 변수 (복사: cp env.production.example .env)
# docker-compose.prod.yml 과 함께 사용합니다.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=elivis
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=elivis

# 서버·Prisma에 쓰는 URL (호스트에서 마이그레이션 실행 시)
DATABASE_URL=postgresql://elivis:change-me-in-production@localhost:5432/elivis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# 반드시 충분히 긴 무작위 문자열로 교체하세요 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret-production
JWT_REFRESH_SECRET=change-me-refresh-secret-production

# ── @repo/api-server ──────────────────────────────────────────────────────────
# API 컨테이너가 바인딩할 포트
API_PORT=4000
API_HOST=0.0.0.0

# 브라우저/웹 앱 출처 (프론트 URL)
CORS_ORIGIN=https://your-domain.com

# 공개 회원가입: DB(AuthSettings)가 없을 때만 첫 생성 시 초기값으로 사용. 이후는 관리자 › 보안 › 외부 회원가입에서 설정.
# PUBLIC_SIGNUP_ENABLED=true
# LDAP: AuthSettings 행이 처음 생성될 때만 아래 값이 DB 초기값으로 시드됩니다. 이후는 관리자 › 보안 › LDAP에서 설정합니다.
# LDAP_ENABLED=true
# LDAP_URL=ldaps://ldap.example.com
# LDAP_USER_DN_TEMPLATE=
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=
# LDAP_SEARCH_FILTER=(mail={{email}})
# LDAP_NAME_ATTRIBUTE=cn

# ── @repo/notification-server ─────────────────────────────────────────────────
NOTIFICATION_PORT=4001
NOTIFICATION_HOST=0.0.0.0

# 파일 저장 위치: "local" 또는 "s3"
UPLOAD_STORAGE=local
# 파일 업로드 최대 크기 (MB 단위), 기본값 50
UPLOAD_MAX_FILE_SIZE_MB=50
# 웹 클라이언트 사이드 검증용 (서버와 동일하게 유지)
NEXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=50

# ── S3 / 호환 오브젝트 스토리지 (UPLOAD_STORAGE=s3 일 때) ───────────────────
# UPLOAD_S3_BUCKET=my-bucket
# UPLOAD_S3_REGION=ap-northeast-2
# UPLOAD_S3_ACCESS_KEY=
# UPLOAD_S3_SECRET_KEY=
# UPLOAD_S3_ENDPOINT=          # 선택 — Cloudflare R2, MinIO 등 커스텀 엔드포인트
# UPLOAD_S3_CDN_URL=           # 선택 — CloudFront 등 CDN 퍼블릭 URL

# ── apps/web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_NOTIFICATION_URL=https://notification.your-domain.com

# ── Electron 정적 빌드 (데스크톱 번들용) ────────────────────────────────────────
# ELECTRON_STATIC=1
