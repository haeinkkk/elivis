generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// 시스템 전체 역할
enum SystemRole {
  SUPER_ADMIN /// 전체 관리자 — 모든 리소스 접근 가능
  USER        /// 일반 사용자 — 소속 프로젝트만 접근
}

/// 프로젝트 내부 직책
enum ProjectRole {
  LEADER         /// 프로젝트장 — 멤버 관리·삭제·설정 변경
  DEPUTY_LEADER  /// 부프로젝트장 — 업무 관리·멤버 초대
  MEMBER         /// 일반 멤버 — 할당된 업무 조회·수정
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  password   String   /// bcrypt 해시 저장
  systemRole SystemRole @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships ProjectMember[]
  tasks       Task[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members ProjectMember[]
  tasks   Task[]
}

/// User ↔ Project 중개 테이블 (다대다 + 직책 포함)
model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 한 유저는 한 프로젝트에 한 번만 소속
  @@unique([userId, projectId])
}

model Task {
  id         String   @id @default(cuid())
  title      String
  status     String   @default("todo")
  projectId  String
  assigneeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}
