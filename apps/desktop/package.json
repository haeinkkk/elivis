{
  "name": "@repo/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node scripts/sync-icon.mjs",
    "sync-icon": "node scripts/sync-icon.mjs",
    "build:desktop": "pnpm run build && electron-builder --config electron-builder.yml",
    "dev": "node scripts/sync-icon.mjs && tsc && concurrently -k \"tsc -w\" \"cross-env ELECTRON_DEV=1 node scripts/run-electron-app.mjs dist/main.js\"",
    "start": "node scripts/run-electron-app.mjs dist/main.js",
    "lint": "node ../../scripts/eslint-run.mjs . --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "^5.3.0"
  }
}
