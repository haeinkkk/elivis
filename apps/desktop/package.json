{
  "name": "@repo/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "build:desktop": "electron-builder --config electron-builder.yml",
    "dev": "concurrently -k \"tsc -w\" \"wait-on tcp:127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron dist/main.js\"",
    "start": "electron dist/main.js",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.1"
  }
}
