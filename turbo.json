{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "API_PORT",
    "API_HOST",
    "CORS_ORIGIN",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_NOTIFICATION_URL",
    "NOTIFICATION_PORT",
    "NOTIFICATION_HOST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "build:desktop": {
      "dependsOn": ["@repo/desktop#build"],
      "outputs": ["release/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    }
  }
}
