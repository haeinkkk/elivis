# 루트에 `.env`로 복사하세요. `@repo/database`의 Prisma 스크립트가 이 파일을 읽습니다.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://elivis:elivis@localhost:5432/elivis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# 반드시 충분히 긴 무작위 문자열로 교체하세요 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# ── @repo/server ──────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ── apps/web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Seeding ───────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@elivis.dev
SEED_ADMIN_PASSWORD=admin1234!

# ── Electron 정적 빌드 (데스크톱 번들용) ────────────────────────────────────────
# ELECTRON_STATIC=1
